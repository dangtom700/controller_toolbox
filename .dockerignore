venv/
env/
environment.yml

# CSV outputs / generated data
*.csv

# Misc OS artifacts
.DS_Store
Thumbs.db

# Windows-only build helpers (not relevant inside a Linux container)
compile.bat
enhance.bat

# Doxygen output
Doxyfile
html/
latex/
